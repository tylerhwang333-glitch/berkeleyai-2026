# --- Backend ---
# Redis connection (Redis Stack recommended for vector search)
REDIS_URL=redis://localhost:6379

# Optional: enable the Anthropic-powered coach. If unset, a deterministic
# fallback coach generator is used and the app still works fully.
ANTHROPIC_API_KEY=
# Optional model override (defaults to claude-opus-4-8)
ANTHROPIC_MODEL=claude-opus-4-8

# --- Frontend ---
# Where the React app reaches the backend.
VITE_BACKEND_URL=http://localhost:8000
